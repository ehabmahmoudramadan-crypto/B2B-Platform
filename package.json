    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:run": "npx typeorm-ts-node-commonjs migration:run -d src/config/database.config.ts",
