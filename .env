# App
NODE_ENV=development
PORT=3000
APP_NAME=B2B Procurement Platform

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=b2b_procurement

# JWT
JWT_SECRET=b2b-super-secret-jwt-key-2024
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# SMS - Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase Push Notifications
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
